msgid "mail.brand_name"
msgstr "CoLDAT"

msgid "mail.footer_text"
msgstr "© 2026 CoLDAT. All rights reserved."

msgid "mail.support_email"
msgstr "support@coldat.app"

# ---------------------------------------------------------------------------
# Email Verification
# ---------------------------------------------------------------------------

msgid "mail.verify_email.subject"
msgstr "Complete the verification process to access your account."
msgid "mail.verify_email.heading"
msgstr "Verify Your Account"
msgid "mail.verify_email.greeting"
msgstr "Hello"

msgid "mail.verify_email.intro_text"
msgstr "Thank you for registering on the CoLDAT platform. Your registration has been successfully completed. You need to complete the verification process to access your account."
msgid "mail.verify_email.cta_instruction_text"
msgstr "You can verify your account by clicking the button below."

msgid "mail.verify_email.cta_label_text"
msgstr "Verify Account"
msgid "mail.verify_email.expiry_notice_text"
msgstr "This link is valid for {hours} hours."

msgid "mail.verify_email.fallback_instruction_text"
msgstr "If the button doesn't work, you can copy and paste the following link into your browser:"

msgid "mail.verify_email.security_notice_text"
msgstr "If you did not create this account, you can safely ignore this email address."

# ---------------------------------------------------------------------------
# Password Reset
# ---------------------------------------------------------------------------

msgid "mail.password_reset.subject"
msgstr "You can reset your password to regain access to your account."

msgid "mail.password_reset.heading"
msgstr "Reset Your Password"

msgid "mail.password_reset.greeting"
msgstr "Hello"

msgid "mail.password_reset.intro_text"
msgstr "We have received a password reset request for your CoLDAT account. We are contacting you to restore your access to your account."

msgid "mail.password_reset.cta_instruction_text"
msgstr "To create a new password, click the button below."

msgid "mail.password_reset.cta_label_text"
msgstr "Reset Password"

msgid "mail.password_reset.expiry_notice_text"
msgstr "This link is valid for {hours} hours for your security."

msgid "mail.password_reset.fallback_instruction_text"
msgstr "If the button doesn't work, you can copy and paste the following link into your browser:"

msgid "mail.password_reset.security_notice_text"
msgstr "If you did not request this password reset, you can ignore this email. Your account will remain secure and your password will not change."

