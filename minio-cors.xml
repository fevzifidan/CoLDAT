<?xml version="1.0" encoding="UTF-8"?>
<CORSConfiguration xmlns="http://s3.amazonaws.com/doc/2006-03-01/">
    <CORSRule>
        <!-- İzin Verilen Kökenler (Allowed Origins) -->
        <AllowedOrigin>http://localhost:5173</AllowedOrigin>
        <AllowedOrigin>http://127.0.0.1:5173</AllowedOrigin>
        <AllowedOrigin>http://localhost:5174</AllowedOrigin>
        <AllowedOrigin>http://127.0.0.1:5174</AllowedOrigin>

        <!-- İzin Verilen Metotlar (Allowed Methods) -->
        <AllowedMethod>GET</AllowedMethod>
        <AllowedMethod>PUT</AllowedMethod>
        <AllowedMethod>HEAD</AllowedMethod>

        <!-- İzin Verilen Başlıklar (Allowed Headers) -->
        <AllowedHeader>*</AllowedHeader>

        <!-- Dışarıya Açık Başlıklar (Expose Headers) -->
        <ExposeHeader>ETag</ExposeHeader>
        <ExposeHeader>x-amz-checksum-sha256</ExposeHeader>

        <!-- Önbellekleme Süresi (Max Age Seconds) -->
        <MaxAgeSeconds>3600</MaxAgeSeconds>
    </CORSRule>
</CORSConfiguration>